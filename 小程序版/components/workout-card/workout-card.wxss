.workout-card {
  background: linear-gradient(145deg, #ffffff, #f8f8f8);
  border-radius: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(0,0,0,0.08);
  width: 560rpx;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.card-icon { font-size: 36rpx; }
.card-title { font-size: 30rpx; font-weight: 600; }
.card-subtext {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-left: auto;
}

/* 训练日列表 */
.day-list { display: flex; flex-direction: column; gap: 10rpx; }

.day-item {
  background: rgba(0,0,0,0.03);
  border-radius: 16rpx;
  overflow: hidden;
  transition: all 0.2s;
}
.day-item.rest { opacity: 0.5; }

.day-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
}
.day-num {
  font-size: 24rpx; font-weight: 700;
  width: 80rpx; color: var(--color-primary);
}
.day-focus { font-size: 28rpx; flex: 1; }
.day-focus.rest-text { color: var(--color-text-secondary); }

.expand-icon {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 动作详情 */
.day-detail {
  padding: 0 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.exercise-item {
  padding: 18rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--color-primary);
}
.ex-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.ex-name { font-size: 28rpx; font-weight: 600; }
.ex-volume {
  font-size: 24rpx; color: var(--color-primary);
  background: rgba(0,212,170,0.1);
  padding: 4rpx 12rpx; border-radius: 8rpx;
}
.ex-notes { font-size: 24rpx; color: var(--color-text-secondary); display: block; }
.ex-rest { font-size: 22rpx; color: var(--color-text-secondary); margin-top: 6rpx; display: block; }
