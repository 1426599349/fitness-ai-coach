/**
 * 授权登录页样式
 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0fdf6 0%, #ffffff 40%);
  padding: 0 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ========== 品牌区 ========== */
.brand-area {
  margin-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(16, 185, 129, 0.25);
  margin-bottom: 24rpx;
}

.logo-icon {
  font-size: 64rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.app-desc {
  font-size: 26rpx;
  color: #9ca3af;
}

/* ========== 授权卡片 ========== */
.auth-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-top: 56rpx;
  padding: 40rpx 36rpx;
}

.card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}

.card-sub {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 36rpx;
}

/* ——— 头像 ——— */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  border: 4rpx dashed #d1d5db;
  background: #f9fafb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  line-height: 1.2;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 0;
}

.avatar-placeholder {
  font-size: 64rpx;
  line-height: 120rpx;
}

.avatar-tip {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

/* ——— 昵称 ——— */
.nickname-section {
  width: 100%;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}

.nickname-placeholder {
  color: #d1d5db;
}

/* ========== 隐私说明 ========== */
.privacy-notice {
  margin-top: 32rpx;
  padding: 20rpx 28rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 6rpx;
}

.privacy-icon {
  font-size: 24rpx;
}

.privacy-text {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.6;
}

.privacy-link {
  font-size: 22rpx;
  color: #10b981;
}

/* ========== 操作按钮 ========== */
.action-area {
  margin-top: 48rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 48rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.confirm-btn::after {
  border: none;
}

.confirm-btn.disabled {
  opacity: 0.5;
}

.skip-link {
  margin-top: 24rpx;
  padding: 12rpx 24rpx;
}

.skip-link text {
  font-size: 26rpx;
  color: #9ca3af;
}
