<view class="splash" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
  <!-- 流动粒子 -->
  <view class="particle p1"></view>
  <view class="particle p2"></view>
  <view class="particle p3"></view>
  <view class="particle p4"></view>
  <view class="particle p5"></view>
  <view class="particle p6"></view>

  <!-- 光晕环 -->
  <view class="glow-ring ring1"></view>
  <view class="glow-ring ring2"></view>
  <view class="glow-ring ring3"></view>

  <!-- 主内容 -->
  <view class="main-content {{fadeOut ? 'fade-out' : ''}}">
    <view class="logo-wrap">
      <view class="logo-ring"></view>
      <text class="logo-icon">💪</text>
    </view>

    <view class="title-area">
      <text class="app-name">动作库</text>
      <view class="divider"></view>
      <text class="tagline">记录每一次训练 · 见证每一次改变</text>
    </view>
  </view>

  <!-- 底部上划 -->
  <view class="swipe-hint {{fadeOut ? 'fade-out' : ''}}">
    <view class="swipe-circle">
      <text class="swipe-arrow">↑</text>
    </view>
    <text class="swipe-text">上划开启</text>
  </view>
</view>
