<view class="splash" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
  <image class="sv-bg" src="/images/splash-poster.jpg" mode="aspectFill" />
  <view class="sv-mask">
    <text class="sv-logo">💪</text>
    <text class="sv-title">动作库</text>
    <view class="sv-line"></view>
    <text class="sv-sub">记录每一次训练 · 见证每一次改变</text>
    <view class="sv-swipe-box">
      <view class="sv-circle"><text class="sv-arrow">↑</text></view>
      <text class="sv-swipe-text">上划开启</text>
    </view>
  </view>
</view>
