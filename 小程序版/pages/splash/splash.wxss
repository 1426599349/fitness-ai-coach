.splash {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: linear-gradient(160deg, #0f0f23 0%, #1a1a3e 40%, #0d2137 100%);
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; overflow: hidden;
}

/* 背景装饰圆 */
.bg-circle {
  position: absolute; border-radius: 50%; opacity: 0.06;
}
.circle1 {
  width: 500rpx; height: 500rpx; background: #00d4aa;
  top: -150rpx; right: -100rpx;
}
.circle2 {
  width: 350rpx; height: 350rpx; background: #00d4aa;
  bottom: 200rpx; left: -80rpx;
}
.circle3 {
  width: 200rpx; height: 200rpx; background: #fff;
  bottom: 300rpx; right: 50rpx; opacity: 0.04;
}

/* 主内容 */
.main-content {
  display: flex; flex-direction: column; align-items: center;
  transition: opacity 0.4s, transform 0.4s;
}
.main-content.fade-out { opacity: 0; transform: translateY(-80rpx); }

.logo-area {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: rgba(0,212,170,0.12); display: flex;
  align-items: center; justify-content: center; margin-bottom: 40rpx;
  border: 2rpx solid rgba(0,212,170,0.2);
}
.logo-text { font-size: 80rpx; }

.title-area { text-align: center; }
.app-name {
  font-size: 52rpx; font-weight: 700; color: #fff; display: block;
  letter-spacing: 8rpx;
}
.tagline {
  font-size: 26rpx; color: rgba(255,255,255,0.5);
  display: block; margin-top: 12rpx;
}

/* 上划提示 */
.swipe-hint {
  position: absolute; bottom: 120rpx;
  display: flex; flex-direction: column; align-items: center;
  transition: opacity 0.3s;
}
.swipe-hint.fade-out { opacity: 0; }

.swipe-text {
  font-size: 26rpx; color: rgba(255,255,255,0.35);
  margin-bottom: 20rpx;
}

.arrow-wrap {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.arrow {
  font-size: 36rpx; color: rgba(255,255,255,0.3);
  transform: rotate(-90deg);
}
.arrow1 { animation: bounce 1.8s infinite; }
.arrow2 { animation: bounce 1.8s 0.15s infinite; }
.arrow3 { animation: bounce 1.8s 0.3s infinite; }

@keyframes bounce {
  0%, 60%, 100% { opacity: 0.2; transform: rotate(-90deg) translateY(0); }
  30% { opacity: 1; transform: rotate(-90deg) translateY(-10rpx); }
}
