.splash { width: 100%; height: 100%; background: #000; }
.splash-video { width: 100%; height: 100%; }
.cover-bottom {
  position: absolute; bottom: 100rpx; left: 0;
  width: 100%; text-align: center;
}
.cover-circle {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.4);
  margin: 0 auto 16rpx;
  line-height: 80rpx; text-align: center;
}
.cover-arrow { font-size: 32rpx; color: rgba(255,255,255,0.7); }
.cover-swipe-text { font-size: 24rpx; color: rgba(255,255,255,0.5); }
