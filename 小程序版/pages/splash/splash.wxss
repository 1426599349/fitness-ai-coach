.sv { position: fixed; top: 0; left: 0; width: 100%; height: 100%; }
.sv-img { width: 100%; height: 100%; }
.sv-mask {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.35);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.sv-logo { font-size: 90rpx; margin-bottom: 50rpx; }
.sv-title {
  font-size: 56rpx; font-weight: 700; color: #fff;
  letter-spacing: 12rpx; margin-bottom: 20rpx;
}
.sv-line { width: 60rpx; height: 3px; background: #00d4aa; border-radius: 2px; margin-bottom: 16rpx; }
.sv-sub { font-size: 24rpx; color: rgba(255,255,255,0.55); }
.sv-swipe-box {
  position: absolute; bottom: 100rpx;
  display: flex; flex-direction: column; align-items: center;
}
.sv-circle {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.4);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 16rpx;
}
.sv-arrow { font-size: 32rpx; color: rgba(255,255,255,0.7); }
.sv-swipe-text { font-size: 24rpx; color: rgba(255,255,255,0.5); }
