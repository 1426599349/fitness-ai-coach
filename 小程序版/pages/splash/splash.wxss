.splash {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: #0a0a1a;
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; overflow: hidden;
}

/* 流动渐变光 */
.splash::before {
  content: ''; position: absolute; top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(ellipse at 30% 20%, rgba(0,212,170,0.12) 0%, transparent 50%),
              radial-gradient(ellipse at 70% 60%, rgba(0,180,216,0.08) 0%, transparent 50%),
              radial-gradient(ellipse at 50% 80%, rgba(0,212,170,0.06) 0%, transparent 40%);
  animation: bgFlow 8s ease-in-out infinite;
}
@keyframes bgFlow {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(2%, -1%) rotate(1deg); }
  66% { transform: translate(-1%, 2%) rotate(-1deg); }
}

/* 浮动粒子 */
.particle {
  position: absolute; border-radius: 50%; background: #00d4aa;
  animation: floatUp 6s ease-in-out infinite;
}
.p1 { width: 6rpx; height: 6rpx; left: 15%; bottom: -20rpx; animation-delay: 0s; opacity: 0.4; }
.p2 { width: 4rpx; height: 4rpx; left: 35%; bottom: -20rpx; animation-delay: 1.2s; opacity: 0.3; }
.p3 { width: 8rpx; height: 8rpx; left: 55%; bottom: -20rpx; animation-delay: 2.4s; opacity: 0.5; }
.p4 { width: 5rpx; height: 5rpx; left: 72%; bottom: -20rpx; animation-delay: 3.6s; opacity: 0.35; }
.p5 { width: 6rpx; height: 6rpx; left: 88%; bottom: -20rpx; animation-delay: 4.8s; opacity: 0.4; }
.p6 { width: 3rpx; height: 3rpx; left: 48%; bottom: -20rpx; animation-delay: 0.8s; opacity: 0.3; }
@keyframes floatUp {
  0% { transform: translateY(0) scale(1); opacity: 0; }
  10% { opacity: 0.5; }
  90% { opacity: 0.5; }
  100% { transform: translateY(-105vh) scale(0.3); opacity: 0; }
}

/* 光晕环 */
.glow-ring {
  position: absolute; border-radius: 50%;
  border: 1rpx solid rgba(0,212,170,0.15);
  animation: pulse 3s ease-in-out infinite;
}
.ring1 { width: 500rpx; height: 500rpx; top: 18%; left: calc(50% - 250rpx); animation-delay: 0s; }
.ring2 { width: 380rpx; height: 380rpx; top: 28%; left: calc(50% - 190rpx); animation-delay: 0.5s; }
.ring3 { width: 260rpx; height: 260rpx; top: 38%; left: calc(50% - 130rpx); animation-delay: 1s; }
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.15; }
  50% { transform: scale(1.08); opacity: 0.35; }
}

/* 主内容 */
.main-content {
  display: flex; flex-direction: column; align-items: center; z-index: 1;
  transition: opacity 0.4s, transform 0.4s;
  animation: fadeInUp 1s ease-out;
}
.main-content.fade-out { opacity: 0; transform: translateY(-80rpx); }
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Logo */
.logo-wrap {
  position: relative; width: 180rpx; height: 180rpx;
  display: flex; align-items: center; justify-content: center; margin-bottom: 50rpx;
}
.logo-ring {
  position: absolute; width: 100%; height: 100%; border-radius: 50%;
  border: 2rpx solid rgba(0,212,170,0.3);
  animation: logoPulse 2s ease-in-out infinite;
}
.logo-ring::after {
  content: ''; position: absolute; top: -4rpx; left: -4rpx;
  right: -4rpx; bottom: -4rpx; border-radius: 50%;
  border: 1rpx solid rgba(0,212,170,0.12);
  animation: logoPulse 2s ease-in-out 0.4s infinite;
}
@keyframes logoPulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.06); opacity: 0.6; }
}
.logo-icon { font-size: 90rpx; position: relative; z-index: 1; animation: logoBreathe 3s ease-in-out infinite; }
@keyframes logoBreathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.12); }
}

/* 标题 */
.title-area { text-align: center; }
.app-name {
  font-size: 56rpx; font-weight: 700; color: #fff; display: block;
  letter-spacing: 12rpx;
  animation: fadeInUp 1s ease-out 0.2s both;
}
.divider {
  width: 60rpx; height: 3rpx; background: #00d4aa;
  margin: 20rpx auto; border-radius: 2rpx;
  animation: fadeInUp 1s ease-out 0.4s both;
}
.tagline {
  font-size: 24rpx; color: rgba(255,255,255,0.4); display: block;
  animation: fadeInUp 1s ease-out 0.5s both;
}

/* 上划提示 */
.swipe-hint {
  position: absolute; bottom: 100rpx; z-index: 1;
  display: flex; flex-direction: column; align-items: center;
  transition: opacity 0.3s;
  animation: fadeInUp 1s ease-out 0.8s both;
}
.swipe-hint.fade-out { opacity: 0; }

.swipe-circle {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 16rpx;
  animation: swipeBounce 2s ease-in-out infinite;
}
@keyframes swipeBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}
.swipe-arrow { font-size: 32rpx; color: rgba(255,255,255,0.5); }
.swipe-text { font-size: 24rpx; color: rgba(255,255,255,0.3); }
