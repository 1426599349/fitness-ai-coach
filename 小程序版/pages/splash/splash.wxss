.splash {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: #0a0a1a;
  overflow: hidden;
}

/* 全屏视频背景 */
.splash-video {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}

/* 半透明遮罩 — cover-view 只支持背景色 */
.video-overlay {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.35);
}

/* ===== 以下全部是 cover-view，只支持基础样式 ===== */

/* 主内容 */
.main-content {
  position: absolute;
  top: 28%;
  left: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: opacity 0.4s, transform 0.4s;
}
.main-content.fade-out {
  opacity: 0;
  transform: translateY(-80rpx);
}

/* Logo */
.logo-wrap {
  width: 180rpx; height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
}
.logo-ring {
  position: absolute;
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 212, 170, 0.4);
}
.logo-icon {
  font-size: 90rpx;
}

/* 标题 */
.title-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.app-name {
  font-size: 56rpx; font-weight: 700;
  color: #fff;
  letter-spacing: 12rpx;
  margin-bottom: 20rpx;
}
.divider {
  width: 60rpx; height: 3rpx;
  background: #00d4aa;
  border-radius: 2rpx;
  margin-bottom: 16rpx;
}
.tagline {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
}

/* 上划提示 */
.swipe-hint {
  position: absolute;
  bottom: 100rpx;
  left: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: opacity 0.3s;
}
.swipe-hint.fade-out {
  opacity: 0;
}

.swipe-circle {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}
.swipe-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}
.swipe-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}
