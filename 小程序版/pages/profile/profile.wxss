.profile-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 30rpx 24rpx;
}

/* 用户头部 */
.profile-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #ffffff, #f8f8f8);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

/* 头像按钮 */
.avatar-btn {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  border: none;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: visible;
}
.avatar-btn::after {
  border: none;
}
.avatar-emoji { font-size: 56rpx; }
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* 头像编辑提示角标 */
.avatar-edit-hint {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

/* 用户信息 */
.user-info {
  flex: 1;
  min-width: 0;
}
.nickname-input {
  width: 100%;
  height: 56rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  padding: 0;
}
.nickname-placeholder {
  color: #b0b0b0;
  font-weight: 400;
}
.user-desc { font-size: 26rpx; color: var(--color-text-secondary); margin-top: 8rpx; display: block; }

/* 保存身份按钮 */
.save-identity-bar {
  padding: 0 0 30rpx;
}
.save-identity-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 40rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(16, 185, 129, 0.25);
}
.save-identity-btn::after {
  border: none;
}

/* 通用Sections */
.section {
  background: var(--color-surface);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 28rpx; font-weight: 600;
  margin-bottom: 20rpx;
}

/* 数据网格 */
.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}
.data-item {
  text-align: center;
  padding: 22rpx 14rpx;
  background: rgba(0,0,0,0.03);
  border-radius: 14rpx;
}
.data-item.editable {
  transition: background 0.15s;
}
.data-item.editable:active {
  background: rgba(0,0,0,0.08);
}
.data-value { font-size: 32rpx; font-weight: 700; color: var(--color-primary); display: block; }
.data-label { font-size: 20rpx; color: var(--color-text-secondary); margin-top: 6rpx; display: block; }

.metrics-row { display: flex; gap: 16rpx; margin-top: 20rpx; }
.metric-chip {
  flex: 1; text-align: center;
  padding: 14rpx;
  background: rgba(0,0,0,0.02);
  border-radius: 10rpx;
}
.m-val { font-size: 24rpx; color: #666; }

/* 体重历史 */
.weight-list { display: flex; flex-direction: column; gap: 14rpx; }
.weight-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(0,0,0,0.03);
  border-radius: 12rpx;
}
.weight-date { flex: 1; font-size: 26rpx; }
.weight-value { font-size: 28rpx; font-weight: 600; }
.weight-change { font-size: 24rpx; margin-left: 16rpx; width: 80rpx; }
.weight-change.up { color: #e74c3c; }
.weight-change.down { color: #00d4aa; }

/* 忌口标签 */
.allergy-tags { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 20rpx; }
.allergy-tag {
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  background: rgba(231, 76, 60, 0.15);
  color: var(--color-danger);
  border-radius: 20rpx;
}

/* 喜欢食材标签 */
.like-tags { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 20rpx; }
.like-tag {
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  background: rgba(46, 204, 113, 0.15);
  color: #27ae60;
  border-radius: 20rpx;
}

.empty-hint {
  font-size: 26rpx; color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.action-row { display: flex; justify-content: flex-end; }
.edit-btn {
  background: var(--color-surface-light) !important;
  color: var(--color-primary) !important;
  font-size: 24rpx !important;
}
.edit-btn.like {
  color: #27ae60 !important;
}

/* 设置列表 */
.settings-list { display: flex; flex-direction: column; }
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.setting-item:last-child { border-bottom: none; }
.arrow { font-size: 36rpx; color: var(--color-text-secondary); }

.bottom-space { height: 60rpx; }
