.meal-card {
  background: linear-gradient(145deg, #ffffff, #f8f8f8);
  border-radius: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(0,0,0,0.08);
  width: 560rpx;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.card-icon { font-size: 36rpx; }
.card-title { font-size: 30rpx; font-weight: 600; flex: 1; }
.regenerate-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(0, 212, 170, 0.1);
}
.regenerate-btn:active { background: rgba(0, 212, 170, 0.2); }

/* 主食 */
.staple-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(0, 212, 170, 0.08);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.staple-tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background: rgba(0,212,170,0.15);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.staple-name {
  font-size: 28rpx; font-weight: 600;
}

/* 菜品列表 */
.dishes-list { display: flex; flex-direction: column; gap: 14rpx; margin-bottom: 24rpx; }
.dish-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 20rpx;
  background: rgba(0,0,0,0.03);
  border-radius: 14rpx;
}
.dish-info { display: flex; gap: 14rpx; align-items: center; }
.dish-name { font-size: 28rpx; }
.dish-grams { font-size: 24rpx; color: var(--color-text-secondary); }
.dish-kcal { font-size: 26rpx; color: var(--color-warning); font-weight: 500; }

/* 营养总结 */
.nutrition-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}
.total-kcal { display: flex; align-items: baseline; gap: 6rpx; }
.kcal-number { font-size: 44rpx; font-weight: 700; color: var(--color-primary); }
.kcal-unit { font-size: 24rpx; color: var(--color-text-secondary); }
.macro-tags { display: flex; gap: 10rpx; }
.macro-tag {
  font-size: 20rpx; padding: 6rpx 14rpx;
  border-radius: 20rpx; color: #fff;
}
.macro-tag.protein { background: rgba(108, 92, 231, 0.6); }
.macro-tag.fat { background: rgba(243, 156, 18, 0.6); }
.macro-tag.carb { background: rgba(0, 212, 170, 0.6); }
