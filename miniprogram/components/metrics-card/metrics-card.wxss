.metrics-card {
  background: linear-gradient(145deg, #ffffff, #f8f8f8);
  border-radius: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(0,0,0,0.08);
  width: 560rpx;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.card-icon { font-size: 36rpx; }
.card-title { font-size: 30rpx; font-weight: 600; }

/* BMI 区域 */
.bmi-section {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}
.bmi-ring {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.bmi-value { font-size: 40rpx; font-weight: 700; color: #fff; }
.bmi-label { font-size: 20rpx; color: rgba(0,0,0,0.7); }
.bmi-level { font-size: 28rpx; font-weight: 600; }

/* 热量网格 */
.metrics-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.metric-item {
  text-align: center;
  padding: 16rpx 8rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 16rpx;
}
.metric-item.highlight {
  background: rgba(0, 212, 170, 0.1);
  border: 1rpx solid rgba(0, 212, 170, 0.3);
}
.metric-value {
  font-size: 32rpx; font-weight: 700;
  color: var(--color-primary);
}
.metric-label { font-size: 20rpx; color: var(--color-text-secondary); margin-top: 6rpx; }

/* 宏量营养素 */
.macros-section { display: flex; flex-direction: column; gap: 16rpx; }
.macro-item { display: flex; align-items: center; gap: 16rpx; }
.macro-bar {
  flex: 1; height: 12rpx;
  background: rgba(0,0,0,0.08);
  border-radius: 6rpx;
  overflow: hidden;
}
.macro-fill { height: 100%; border-radius: 6rpx; }
.macro-fill.protein { background: #6c5ce7; }
.macro-fill.fat { background: #f39c12; }
.macro-fill.carb { background: #00d4aa; }
.macro-text { font-size: 22rpx; color: var(--color-text-secondary); white-space: nowrap; }
