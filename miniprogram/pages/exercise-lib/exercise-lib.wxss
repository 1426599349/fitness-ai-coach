.lib-page { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }
.search-bar { display: flex; align-items: center; gap: 16rpx; padding: 20rpx 24rpx; background: #fff; }
.search-input { flex: 1; height: 64rpx; background: #f0f0f0; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; }
.place-btn { padding: 10rpx 20rpx; border-radius: 12rpx; font-size: 24rpx; background: #f0f0f0; }
.place-btn.active { background: var(--color-primary); color: #fff; }
.filter-bar { white-space: nowrap; padding: 16rpx 24rpx; background: #fff; border-bottom: 1rpx solid #eee; }
.filter-tag { display: inline-block; padding: 10rpx 24rpx; margin-right: 16rpx; border-radius: 20rpx; font-size: 26rpx; background: #f0f0f0; }
.filter-tag.active { background: var(--color-primary); color: #fff; font-weight: 600; }
.ex-list { flex: 1; padding: 0 24rpx; }
.ex-row { display: flex; align-items: center; gap: 16rpx; padding: 24rpx; background: #fff; border-radius: 12rpx; margin-bottom: 8rpx; }
.ex-row:active { background: #f8f8f8; }
.ex-muscle-tag { padding: 4rpx 14rpx; border-radius: 8rpx; font-size: 22rpx; color: #fff; font-weight: 600; min-width: 56rpx; text-align: center; flex-shrink: 0; }
.ex-name { font-size: 28rpx; flex: 1; }
.ex-arrow { font-size: 36rpx; color: #ccc; }
.empty { text-align: center; padding: 60rpx; color: #aaa; font-size: 28rpx; }
