.lib-page { min-height: 100vh; background: #f5f5f5; padding-top: 20rpx; }

.filter-bar { white-space: nowrap; padding: 0 24rpx 20rpx; }
.filter-tag {
  display: inline-block; padding: 12rpx 28rpx; margin-right: 16rpx;
  border-radius: 30rpx; font-size: 26rpx; background: #fff; color: #666;
}
.filter-tag.active { background: #00d4aa; color: #fff; }

.food-list { padding: 0 24rpx; height: calc(100vh - 120rpx); }
.food-row {
  display: flex; align-items: center; padding: 24rpx 20rpx;
  background: #fff; border-radius: 14rpx; margin-bottom: 12rpx; gap: 16rpx;
}
.food-info { flex: 1; min-width: 0; }
.food-name { font-size: 30rpx; font-weight: 600; display: block; }
.food-meta { font-size: 22rpx; color: #999; margin-top: 6rpx; display: block; }
.food-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; flex-shrink: 0; }
.food-tag.staple { background: #fff3e0; color: #e67e22; }
.food-tag.main { background: #fdecea; color: #e74c3c; }
.food-tag.side { background: #e8f5e9; color: #27ae60; }
.arrow { font-size: 36rpx; color: #ccc; }
