<scroll-view class="admin-page" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="header">
    <text class="title">📊 数据看板</text>
    <text class="subtitle">仅管理员可见</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="error" wx:if="{{error}}">
    <text>{{error}}</text>
  </view>

  <view wx:if="{{!loading && !error}}">
    <!-- 核心指标 -->
    <view class="section">
      <view class="section-title">📈 核心指标</view>
      <view class="metric-grid">
        <view class="metric-card">
          <text class="metric-val">{{totalUsers}}</text>
          <text class="metric-label">累计用户</text>
        </view>
        <view class="metric-card">
          <text class="metric-val">{{todayActive}}</text>
          <text class="metric-label">今日活跃</text>
        </view>
        <view class="metric-card">
          <text class="metric-val">{{todaySignin}}</text>
          <text class="metric-label">今日签到</text>
        </view>
      </view>
    </view>

    <!-- 功能使用 -->
    <view class="section">
      <view class="section-title">🔧 功能数据</view>
      <view class="metric-grid">
        <view class="metric-card">
          <text class="metric-val">{{plansGenerated}}</text>
          <text class="metric-label">累计生成计划</text>
        </view>
        <view class="metric-card">
          <text class="metric-val">{{plansUpdated}}</text>
          <text class="metric-label">计划更新次数</text>
        </view>
        <view class="metric-card">
          <text class="metric-val">{{mealsGenerated}}</text>
          <text class="metric-label">饮食方案生成</text>
        </view>
        <view class="metric-card">
          <text class="metric-val">{{exercisesDone}}</text>
          <text class="metric-label">动作完成勾选</text>
        </view>
      </view>
    </view>

    <!-- 留存数据 -->
    <view class="section" wx:if="{{signupByDay.length > 0}}">
      <view class="section-title">📅 每日新增用户</view>
      <view class="chart-list">
        <view class="chart-row" wx:for="{{signupByDay}}" wx:key="date">
          <text class="chart-date">{{item.date}}</text>
          <view class="chart-bar-wrap">
            <view class="chart-bar" style="width: {{item.count / maxSignup * 100}}%"></view>
          </view>
          <text class="chart-val">{{item.count}}人</text>
        </view>
      </view>
    </view>

    <view class="footer">刷新页面即可更新数据</view>
  </view>
</scroll-view>
