.detail-page { min-height: 100vh; background: #f5f5f5; }
.img-area { width: 100%; height: 500rpx; display: flex; align-items: center; justify-content: center; }
.ex-img { width: 100%; height: 100%; }
.ex-placeholder { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; }
.ph-emoji { font-size: 120rpx; opacity: 0.55; }
.ph-name { font-size: 40rpx; font-weight: 700; color: #333; }
.ph-muscle { font-size: 26rpx; color: #999; margin-top: 4rpx; }
.info-card { margin: 20rpx 24rpx; padding: 28rpx; background: #fff; border-radius: 16rpx; }
.ex-title { font-size: 36rpx; font-weight: 700; }
.tag-row { display: flex; gap: 12rpx; margin-top: 16rpx; }
.tag { padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; color: #fff; }
.tag.level { background: #888; }
.tag.place { background: #ddd; color: #555; }
.tips-card { margin: 0 24rpx 40rpx; padding: 28rpx; background: #fff; border-radius: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 700; margin-bottom: 20rpx; }
.detail-text { font-size: 28rpx; color: #444; line-height: 1.8; text-align: justify; }
