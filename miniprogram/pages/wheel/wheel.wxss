.wheel-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f5f5 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
}

.today-status {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 40rpx;
  padding: 20rpx 32rpx;
  background: var(--color-surface);
  border-radius: 20rpx;
}
.status-icon { font-size: 36rpx; }
.status-text { font-size: 28rpx; color: var(--color-text-secondary); }

/* 今日结果 */
.today-meals {
  width: 100%; display: flex; flex-direction: column; gap: 16rpx;
  margin-bottom: 40rpx;
}
.meal-row {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx; background: var(--color-surface);
  border-radius: 18rpx;
}
.meal-row:active { background: rgba(0,212,170,0.06); }
.meal-emoji { font-size: 40rpx; }
.meal-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.meal-title { font-size: 24rpx; color: var(--color-text-secondary); }
.meal-food { font-size: 28rpx; font-weight: 700; color: var(--color-primary); }
.meal-arrow { font-size: 36rpx; color: var(--color-text-secondary); }

/* 按钮 */
.wheel-action-area {
  display: flex; flex-direction: column; align-items: center;
  gap: 16rpx; margin-top: auto; padding-bottom: 60rpx;
}
.retry-area {
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
}
.retry-spin-btn {
  width: 500rpx; height: 100rpx; line-height: 100rpx;
  border-radius: 50rpx; font-size: 30rpx; font-weight: 700;
  background: linear-gradient(135deg, #6c5ce7, #e74c3c);
  color: #fff; border: none; text-align: center;
}
.retry-spin-btn::after { border: none; }
.big-spin-btn {
  width: 500rpx; height: 100rpx; line-height: 100rpx;
  border-radius: 50rpx; font-size: 34rpx; font-weight: 700;
  background: linear-gradient(135deg, var(--color-primary), #6c5ce7);
  color: #fff; border: none; text-align: center;
}
.big-spin-btn.used { opacity: 0.4; }
.big-spin-btn::after { border: none; }
.hint { font-size: 24rpx; color: var(--color-text-secondary); }

/* 饮食详情卡片 */
.meal-detail-card {
  background: var(--color-surface);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
}
.card-meal-header {
  display: flex; align-items: center; gap: 10rpx;
  margin-bottom: 14rpx;
}
.card-emoji { font-size: 36rpx; }
.card-meal-label { font-size: 28rpx; font-weight: 700; }
.card-staple {
  font-size: 32rpx; font-weight: 700; color: var(--color-primary);
  display: block; margin-bottom: 16rpx;
}
.card-dishes { display: flex; flex-direction: column; gap: 10rpx; margin-bottom: 16rpx; }
.card-dish {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12rpx 16rpx;
  background: rgba(0,0,0,0.03);
  border-radius: 10rpx;
}
.dish-name { font-size: 26rpx; }
.dish-nutrition { font-size: 22rpx; color: var(--color-text-secondary); }
.card-summary {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}
.summary-kcal { font-size: 32rpx; font-weight: 700; color: var(--color-primary); }
.summary-macro { font-size: 22rpx; color: var(--color-text-secondary); }
